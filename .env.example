# Copy to ".env" in the project root and fill in (do not commit .env).
# OS environment variables override these entries.
#
# Confluent Cloud → Cluster settings → Bootstrap server
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxx.region.provider.confluent.cloud:9092
# Confluent Cloud → API keys (key = username, secret = password for SASL PLAIN)
CONFLUENT_API_KEY=
CONFLUENT_API_SECRET=
